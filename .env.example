APP_NAME="Paktia Market"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Set to true in production deployments behind HTTPS so the session cookie
# is never sent over plaintext.
SESSION_SECURE_COOKIE=false
# Same-site policy for the session cookie. "lax" is the safe default.
SESSION_SAME_SITE=lax
CUSTOMER_SESSION_COOKIE=paktia_market_customer_session
CUSTOMER_SESSION_TTL=43200
CUSTOMER_SESSION_DOMAIN=null
CUSTOMER_SESSION_SECURE=false
CUSTOMER_SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Sanctum first-party token TTL (minutes). Defaults to 60 days when unset.
# Set to an empty value or remove to disable expiration (not recommended).
SANCTUM_EXPIRATION=86400
# Comma-separated list of domains that should receive stateful Sanctum
# cookies (your SPA hosts). Set this explicitly in production; the local
# default fallback should NOT be relied on.
# SANCTUM_STATEFUL_DOMAINS=app.example.com,admin.example.com

# Comma-separated frontend origins allowed to call the API with credentials.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Branch-sync credentials
# How often (seconds) the credential's last_used_at is refreshed.
POS_SYNC_LAST_USED_THROTTLE_SECONDS=60
# Disallow issuing wildcard ('*') ability tokens unless explicitly opted in.
# Leave this off in production; flip to true only for one-off seeding.
POS_SYNC_ALLOW_WILDCARD_ABILITY=false

# Mobile / Web API client headers
MOBILE_APP_KEY_IOS=ios_59KAj_y_nIxdNB65PK4acqWzSw4h77CjIH1roxnyTxg
MOBILE_APP_KEY_ANDROID=android_vSkAf5NXCMT3FBqz88k3-mSo08rF01ml1OyvICIMzzQ
FIREBASE_PROJECT_ID=
FIREBASE_KEYS_CACHE_SECONDS=3600
# Enable only for local testing when you want to skip real Firebase token verification.
MOBILE_FIREBASE_STUB_MODE=true

# HTTP security headers (see config/security.php)
# Set SECURITY_HSTS_PRELOAD only after registering on the HSTS preload list.
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=false
# Optional Content-Security-Policy. Uncomment and tune per deployment.
# SECURITY_CSP="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'self'"

VITE_APP_NAME="${APP_NAME}"
